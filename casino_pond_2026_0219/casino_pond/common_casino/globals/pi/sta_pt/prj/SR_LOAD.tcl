set min_arrival_delay 1000.0
set max_pin_out "NONE"
set min_pin_out "NONE"

puts [string repeat "-" 93]
puts "SR_LOAD3 pins Data arrival delay"
puts [string repeat "-" 93]
puts "[format "%-s %-54s | %-s %-10s | %-s" "Start" "point" "End" "point" "Delay"]"
puts [string repeat "-" 93]

foreach EP $pins {
    set path_col [get_timing_path -delay $max_min -from [get_clocks {iclk sr_load_0 sr_load_1}] -to $EP]
    
    if {[sizeof_collection $path_col] == 0} {
        puts [format "%-60s | %-14s | %s" "No Path" $EP "N/A"]
        continue
    }

    set arrival_delay [get_attr $path_col arrival]
    
    if {$arrival_delay == ""} {
        puts [format "%-60s | %-14s | %s" "No Arrival" $EP "N/A"]
        continue
    }

    set SP [get_object_name [get_attr $path_col startpoint]]
    
    lappend all_arrival_delay $arrival_delay
    
    if {$arrival_delay > $max_arrival_delay} {
        set max_arrival_delay $arrival_delay
        set max_pin_out $EP
    }
    if {$arrival_delay < $min_arrival_delay} {
        set min_arrival_delay $arrival_delay
        set min_pin_out $EP
    }

    puts [format "%-60s | %-14s | %-.3fns" $SP $EP $arrival_delay]
 }

puts [string repeat "-" 93]

if {[llength $all_arrival_delay] == 0} {
    puts "Error: No valid timing paths found for any pins."
} else {
    set arrival_skew [format "%.3f" [expr $max_arrival_delay - $min_arrival_delay]]
    puts "[format "%-s %-16s : %-.3fns " "Max_arrival_delay" $max_pin_out $max_arrival_delay]"
    puts "[format "%-s %-16s : %-.3fns " "Min_arrival_delay" $min_pin_out $min_arrival_delay]"
    puts "Data skew : ${arrival_skew}ns"

    if {$arrival_skew > 7.0} {
        puts "Result    : FAIL"
    } else {
        puts "Result    : PASS"
    }
}
